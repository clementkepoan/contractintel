# App defaults live in backend/config.py.
# Use this file only to override them.
# If LOCAL_MODEL_BASE_URL / EMBEDDING_MODEL_BASE_URL are left blank:
# - host-native backend defaults to http://127.0.0.1:11434/v1
# - docker backend defaults to http://host.docker.internal:11434/v1
LOCAL_MODEL_NAME=lmstudio-community/Qwen3-4B-Instruct-2507-MLX-5bit
LOCAL_QUERY_MODEL_NAME=Qwen3.5-9B-Claude-4.6-HighIQ-INSTRUCT-HERETIC-UNCENSORED-mlx-4Bit
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=1111
LOCAL_MODEL_NUM_CTX=8192
LOCAL_MODEL_ENABLE_THINKING=false
LOCAL_MODEL_TEMPERATURE=1.0
LOCAL_MODEL_TOP_P=0.95
LOCAL_MODEL_TOP_K=20
LOCAL_MODEL_MIN_P=0.0
LOCAL_MODEL_PRESENCE_PENALTY=1.5
LOCAL_MODEL_REPETITION_PENALTY=1.0
LOCAL_MODEL_FREQUENCY_PENALTY=0.0
EMBEDDING_MODEL_NAME=Qwen3-Embedding-0.6B-4bit-DWQ
EMBEDDING_MODEL_BASE_URL=
EMBEDDING_MODEL_API_KEY=1111

# Leave blank to use runtime default:
# - host-native backend -> http://127.0.0.1:6333
# - docker backend -> http://qdrant:6333
QDRANT_URL=
QDRANT_COLLECTION_NAME=contract_chunks
