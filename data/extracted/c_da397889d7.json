  "blocks": [
    {
      "block_id": "01XX專案_block_0000",
      "text": "專案名稱",
      "para_start": 0,
      "para_end": 0,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0001",
      "text": "XX專案",
      "para_start": 1,
      "para_end": 1,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0002",
      "text": "專案地點",
      "para_start": 2,
      "para_end": 2,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0003",
      "text": "臺南市",
      "para_start": 3,
      "para_end": 3,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0004",
      "text": "智慧能源管理系統",
      "para_start": 4,
      "para_end": 4,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0005",
      "text": "設計原則與內容範圍:",
      "para_start": 5,
      "para_end": 5,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0006",
      "text": "可整合如智慧三表、智慧配電盤及環境感測器等多種智慧物聯網感測 裝置蒐集現場負載及迴路能源耗用資訊， 包括但不限於全大樓用電、太陽能、電動車...用電資料收集。系統不單限於新總部大樓，透過Open API介面，提供支援納入其他廠區的能源管理。產出相對應的報表。並且提供智慧用電調度管理服務 及可視化決策分析試算工具。",
      "para_start": 6,
      "para_end": 6,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0007",
      "text": "耗能管理",
      "para_start": 7,
      "para_end": 7,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0008",
      "text": "記錄全棟樓耗能管理(用水用電)，整合太陽能發電管理，實現能源使用可視化。",
      "para_start": 8,
      "para_end": 8,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0009",
      "text": "所有能源消耗數據需實時更新，確保數據的準確性和及時性。",
      "para_start": 9,
      "para_end": 9,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0010",
      "text": "支持歷史數據查詢，便於進行長期能耗分析和管理。",
      "para_start": 10,
      "para_end": 10,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0011",
      "text": "能源消耗數據需支持多種格式的導出，便於進行數據分析和報告生成。",
      "para_start": 11,
      "para_end": 11,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0012",
      "text": "設置耗能異常報警，當能耗超過預設值時自動通知管理人員。",
      "para_start": 12,
      "para_end": 12,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0013",
      "text": "支持區域分類的能耗統計，便於精確管理和分配能源資源。",
      "para_start": 13,
      "para_end": 13,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0014",
      "text": "能耗分析",
      "para_start": 14,
      "para_end": 14,
      "page_estimate": 1
    },
    {
      "block_id": "01XX專案_block_0015",
      "text": "系統需具備能耗分析功能，提供節能建議，提升能源使用效率。",
      "para_start": 15,
      "para_end": 15,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0016",
      "text": "能耗分析需覆蓋電力、照明、空調、公共設備具、用水等各個方面。",
      "para_start": 16,
      "para_end": 16,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0017",
      "text": "能耗分析報告需具備圖表展示功能，便於直觀查看能耗趨勢。",
      "para_start": 17,
      "para_end": 17,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0018",
      "text": "提供節能措施的模擬和預測功能，幫助制定節能策略。",
      "para_start": 18,
      "para_end": 18,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0019",
      "text": "系統需具備節能效果評估功能，分析節能措施實施後的實際效果。",
      "para_start": 19,
      "para_end": 19,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0020",
      "text": "中央監控平台",
      "para_start": 20,
      "para_end": 20,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0021",
      "text": "整合建商中控系統(BA)，統一管理和監控所有能源設備。",
      "para_start": 21,
      "para_end": 21,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0022",
      "text": "平台需具備實際數據展示功能，便於管理人員隨時查看能源使用情況。",
      "para_start": 22,
      "para_end": 22,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0023",
      "text": "支持多用戶訪問電腦手機等..，不同用戶可設置不同的訪問權限。",
      "para_start": 23,
      "para_end": 23,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0024",
      "text": "設置自動報警和通知功能，當系統檢測到異常能耗或設備故障時，及時通知相關人員。",
      "para_start": 24,
      "para_end": 24,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0025",
      "text": "平台需具備數據備份和恢復功能，防止數據丟失。",
      "para_start": 25,
      "para_end": 25,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0026",
      "text": "提供定期報告生成功能，生成週報、月報、年報，便於管理層了解能源使用情況和趨勢。",
      "para_start": 26,
      "para_end": 26,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0027",
      "text": "界面操作使用規範",
      "para_start": 27,
      "para_end": 27,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0028",
      "text": "界面應簡潔明了，避免冗餘信息，突出關鍵數據和操作。",
      "para_start": 28,
      "para_end": 28,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0029",
      "text": "提供清晰的導航結構，確保用戶能夠快速找到所需功能和信息。",
      "para_start": 29,
      "para_end": 29,
      "page_estimate": 2
    },
    {
      "block_id": "01XX專案_block_0030",
      "text": "所有界面元素應保持一致的設計風格和操作邏輯，避免用戶混淆。",
      "para_start": 30,
      "para_end": 30,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0031",
      "text": "面操作應具有良好的響應速度，避免用戶等待時間過長。",
      "para_start": 31,
      "para_end": 31,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0032",
      "text": "智慧辦公室",
      "para_start": 32,
      "para_end": 32,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0033",
      "text": "設計原則與內容範圍: 智慧辦公屬於新總部，所有智慧應用的入口網站。員工可透過該Line App網站存取[資源預約系統]、[報修派工系統]。並且整合大成長城的員工登入帳號來做資源存取的控制。",
      "para_start": 33,
      "para_end": 33,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0034",
      "text": "員工登入智慧辦公系統，系統主動連結Line、HR系統工號、大成員工入口帳號",
      "para_start": 34,
      "para_end": 34,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0035",
      "text": "智慧辦公系統包括以下系統",
      "para_start": 35,
      "para_end": 35,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0036",
      "text": "資源預約系統(包含會議室、公務車、交誼廳)",
      "para_start": 36,
      "para_end": 36,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0037",
      "text": "行服報修與派工系統",
      "para_start": 37,
      "para_end": 37,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0038",
      "text": "系統開發規範，以下規範以上述系統為本次自行客製系統，而非既有產品",
      "para_start": 38,
      "para_end": 38,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0039",
      "text": "需要提供原始碼，讓大成資訊能承接後續維護專案",
      "para_start": 39,
      "para_end": 39,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0040",
      "text": "開發系統以Net Code C# 程式為主",
      "para_start": 40,
      "para_end": 40,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0041",
      "text": "應用程式需跑在Linux ubuntu上",
      "para_start": 41,
      "para_end": 41,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0042",
      "text": "關聯資料庫須以 Postgres SQL 為主",
      "para_start": 42,
      "para_end": 42,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0043",
      "text": "智慧辦公系統服務都需要支援Restful API介面",
      "para_start": 43,
      "para_end": 43,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0044",
      "text": "智慧辦公系統都需要整合Windows AD 驗證",
      "para_start": 44,
      "para_end": 44,
      "page_estimate": 3
    },
    {
      "block_id": "01XX專案_block_0046",
      "text": "資源預約系統(包含會議室、公務車、書籍借閱、投影機借用與其他資源)",
      "para_start": 46,
      "para_end": 46,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0047",
      "text": "設計原則與內容範圍: 辦公室資訊的預約、租用、借用管理系統。並且資源不限制場域。",
      "para_start": 47,
      "para_end": 47,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0048",
      "text": "資源預約系統提供管理後台介面，可透過Web GUI存取及操作管理管理後臺",
      "para_start": 48,
      "para_end": 48,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0049",
      "text": "資源預約系統Web GUI管理後台支援SSL/TLS 安群機制作為存取保護",
      "para_start": 49,
      "para_end": 49,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0050",
      "text": "資源預約系統須整合AD帳號權限管理",
      "para_start": 50,
      "para_end": 50,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0051",
      "text": "後台管理系統可支援腳色分群",
      "para_start": 51,
      "para_end": 51,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0052",
      "text": "資源管理系統提供Restful Api，可透過api進行資源預約功能",
      "para_start": 52,
      "para_end": 52,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0053",
      "text": "資源預約系統，可於後台新增預約的資源。包括 會議室、公務車、KTV..等。",
      "para_start": 53,
      "para_end": 53,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0054",
      "text": "內建 RBS 軟體，可與主流行事曆系統整合，如微軟 Office 365、Google Workspace 與微軟 Exchange 伺服器。",
      "para_start": 54,
      "para_end": 54,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0055",
      "text": "會議室門口需要有平板，平板規格為10.1 吋電容式觸控面板，上面可顯示目前這個會議室裡面進行的會議。",
      "para_start": 55,
      "para_end": 55,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0056",
      "text": "會議室平板支援乙太網路供電（PoE），可透過一條乙太網路線傳輸電源和 資訊。",
      "para_start": 56,
      "para_end": 56,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0057",
      "text": "會議室門口有QRcode，直接掃描QRcode可以直接租借系統。",
      "para_start": 57,
      "para_end": 57,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0058",
      "text": "會議室系統能產出使用者租借卻沒使用紀錄",
      "para_start": 58,
      "para_end": 58,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0059",
      "text": "公務車預約系統，員工可以通過網站預約公務車，並且填寫必要的欄位。",
      "para_start": 59,
      "para_end": 59,
      "page_estimate": 4
    },
    {
      "block_id": "01XX專案_block_0060",
      "text": "公務車使用完畢，歸還時，直接透過App 拍照或輸入來回報使用里程。",
      "para_start": 60,
      "para_end": 60,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0061",
      "text": "預約系統以Web GUI版架構開發，並且提供 Line App。",
      "para_start": 61,
      "para_end": 61,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0062",
      "text": "資源預約系統支持OpenApi，可供外部AP透過API 來對資源進行預約與取消的動作。",
      "para_start": 62,
      "para_end": 62,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0063",
      "text": "支援多種瀏覽器：可支援 Window IE10 以上、Google Chrome、Apple Safari、Firefox、Opera 等主流瀏覽器。",
      "para_start": 63,
      "para_end": 63,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0064",
      "text": "依 HTML5 標準，瀏覽器不需額安裝程式或套件，不需透過 Java 或 Flash 等程式執行。可在智慧型手機與平板上直接開啟觀看。",
      "para_start": 64,
      "para_end": 64,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0065",
      "text": "竣工後，廠商須提供以下文件",
      "para_start": 65,
      "para_end": 65,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0066",
      "text": "操作手冊。",
      "para_start": 66,
      "para_end": 66,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0067",
      "text": "規格技術文件。",
      "para_start": 67,
      "para_end": 67,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0068",
      "text": "工作相關之竣工圖，如接線圖、安裝圖、平面佈置圖及線路配置圖等。",
      "para_start": 68,
      "para_end": 68,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0069",
      "text": "報修與派工系統",
      "para_start": 69,
      "para_end": 69,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0070",
      "text": "設計原則與內容範圍: 管理公司設備的修繕作業。員工可以在發現公司各種辦公室資產損壞時，利用系統拍照、立案報修。管理資產維修保養狀態。",
      "para_start": 70,
      "para_end": 70,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0071",
      "text": "報工系統提供Web GUI管理後台，並且支援SSL/TLS 安群機制作為存取保護",
      "para_start": 71,
      "para_end": 71,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0072",
      "text": "報工系統需整合AD驗證",
      "para_start": 72,
      "para_end": 72,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0073",
      "text": "報工系統具備權限設計，可以依據設定與分組權限。",
      "para_start": 73,
      "para_end": 73,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0074",
      "text": "系統可以建立場域。例如永康總公司、馬稠後食品場。",
      "para_start": 74,
      "para_end": 74,
      "page_estimate": 5
    },
    {
      "block_id": "01XX專案_block_0075",
      "text": "員工可以透過Line App 報修物品壞損。",
      "para_start": 75,
      "para_end": 75,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0076",
      "text": "派工系統可拍照上傳",
      "para_start": 76,
      "para_end": 76,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0077",
      "text": "權責單位可透過網站查詢報工單。",
      "para_start": 77,
      "para_end": 77,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0078",
      "text": "每一筆報工單可產生工單單號，後續工單單號可勾稽電子簽核系統的費用與SAP成本歸屬。",
      "para_start": 78,
      "para_end": 78,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0079",
      "text": "報工系統需要能對物件進行維修保養的生命週期管理",
      "para_start": 79,
      "para_end": 79,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0080",
      "text": "報工系統可提醒財產保管人物品需要進行例行性的保養",
      "para_start": 80,
      "para_end": 80,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0081",
      "text": "報工系統提供保養管理介面，讓保管人可以上傳保養文件",
      "para_start": 81,
      "para_end": 81,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0082",
      "text": "報工系統提供API，可透過API來存取資料",
      "para_start": 82,
      "para_end": 82,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0083",
      "text": "系統具備GUI報表後台，可以分析各項物品的維修狀態進行分析",
      "para_start": 83,
      "para_end": 83,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0084",
      "text": "報表後台可以轉匯出Excel檔案功能。",
      "para_start": 84,
      "para_end": 84,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0085",
      "text": "系統可以針對工單指派該項目的維修人。",
      "para_start": 85,
      "para_end": 85,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0086",
      "text": "支援多種瀏覽器：可支援 Window IE10 以上、Google Chrome、Apple Safari、Firefox、Opera 等主流瀏覽器。",
      "para_start": 86,
      "para_end": 86,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0087",
      "text": "依 HTML5 標準，瀏覽器不需額安裝程式或套件，不需透過 Java 或 Flash 等程式執行。可在智慧型手機與平板上直接開啟觀看。",
      "para_start": 87,
      "para_end": 87,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0088",
      "text": "軟體保固規範",
      "para_start": 88,
      "para_end": 88,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0089",
      "text": "交付應用系統程式經驗收確定後，廠商須提供操作作業之輔導與教育訓練。教育時間由雙方約定。",
      "para_start": 89,
      "para_end": 89,
      "page_estimate": 6
    },
    {
      "block_id": "01XX專案_block_0090",
      "text": "軟體交付後，經驗收後，始為軟體保固的開始。軟體保固期為一年。",
      "para_start": 90,
      "para_end": 90,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0091",
      "text": "系統功能異常修正 (Bug Fix)",
      "para_start": 91,
      "para_end": 91,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0092",
      "text": "系統上線後須配合本機關網頁弱點掃描、滲透測試或其他資安工 具之檢測並修補漏洞，協助本機關強化程式安全性。",
      "para_start": 92,
      "para_end": 92,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0093",
      "text": "硬體保固維護責任：本契約之保養維修責任採全責制，保固期內發現 之故障或瑕疵，應由廠商於機關指定之合理期限內負責免費無條件 改正。逾期不為改正者，機關得逕為處理，所需費用由廠商負擔， 或動用保固保證金逕為處理，不足時向廠商追償。但屬故意破壞、 不當使用、正常零附件損耗或其他非可歸責於廠商之事由所致瑕疵 者，由機關負擔改正費用",
      "para_start": 93,
      "para_end": 93,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0094",
      "text": "軟體維護以及教育訓練",
      "para_start": 94,
      "para_end": 94,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0095",
      "text": "中文操作與維護資料",
      "para_start": 95,
      "para_end": 95,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0096",
      "text": "製造商之操作與維護手冊",
      "para_start": 96,
      "para_end": 96,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0097",
      "text": "完整說明各項產品及其操作步驟與維護",
      "para_start": 97,
      "para_end": 97,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0098",
      "text": "為確保本案資通系統安全性與完整性，契約期間如有 SQL Injection 、 Cross Site Scripting(XSS)、及其它 OWASP 歷年公布之十大資安弱 點項目等問題(含機關或委外檢測時發現、國家資通安全會報技術服 務中心通報、其他通報管道)，廠商應與機關研議後，配合時程修正 並提交修正結果報告，修正成本請包含於契約價金內。",
      "para_start": 98,
      "para_end": 98,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0099",
      "text": "廠商應視需求提供完整之系統架構說明、系統分析設計、資料庫欄 位設計等使用表單，經由機關相關人員確認後方能執行程式開發。",
      "para_start": 99,
      "para_end": 99,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0100",
      "text": "廠商應確實控管程式與文件版本之一致性。",
      "para_start": 100,
      "para_end": 100,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0101",
      "text": "非廠商自行開發之系統或資源者，應標示非自行開發之內容與其來 源及提供授權證明。",
      "para_start": 101,
      "para_end": 101,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0102",
      "text": "廠商於本專案所提供各項軟硬體設備，在履約期間及機關網路架 構下，應能達成修補或漏洞目標，有效防止漏洞、弱點所造成危害。",
      "para_start": 102,
      "para_end": 102,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0103",
      "text": "廠商在執行業務前應透過機關網站、雙方契約或其他書面文件了解 並遵守機關「資訊安全政策」及相關資通安全規範，並應簽訂「廠 商保密切結書」，其提供服務之人員均需簽署「保密同意書」。",
      "para_start": 103,
      "para_end": 103,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0104",
      "text": "廠商服務人員簽署「保密同意書」時，簽署人應閱讀「保密同意書」 背面之「個人資料蒐集告知事項」，並於該頁尾簽名，以確認簽署者 了解機關對其所簽署個人資料之管理相關事宜。",
      "para_start": 104,
      "para_end": 104,
      "page_estimate": 7
    },
    {
      "block_id": "01XX專案_block_0105",
      "text": "附件(二) 委外資通安全條款-資通硬體採購",
      "para_start": 105,
      "para_end": 105,
      "page_estimate": 8
    },
    {
      "block_id": "01XX專案_block_0106",
      "text": "廠商應提供相關佐證證明所交付之設備，如產地為中 國，須提供第三方公正單位檢驗報告證明或切結主要零組件無不當資訊收集或傳送功能。",
      "para_start": 106,
      "para_end": 106,
      "page_estimate": 8
    },
    {
      "block_id": "01XX專案_block_0107",
      "text": "物聯網設備以無線連接網路者，應採用具加密協定之無線存取點 連接網路，並以網路卡卡號白名單等機制進行設備綁定。",
      "para_start": 107,
      "para_end": 107,
      "page_estimate": 8
    },
    {
      "block_id": "01XX專案_block_0108",
      "text": "物聯網設備應具備身分驗證機制，並應進行初始密碼變更，且應 具備安全性更新機制。",
      "para_start": 108,
      "para_end": 108,
      "page_estimate": 8
    }
